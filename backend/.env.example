# サーバー設定
PORT=3001

# OpenAI API Key
# Get your API key from https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# シフト生成に使用するOpenAIモデル（省略時はgpt-4oを使用）
OPENAI_MODEL=gpt-4o

# Database URL
# PostgreSQL connection string
# LOCAL環境（ローカル開発）: postgresql://user:password@localhost:5432/shift_scheduler
# STG環境（ステージング）: Railway PostgreSQL URL
# PRD環境（本番）: Production PostgreSQL URL
DATABASE_URL=postgresql://user:password@localhost:5432/shift_scheduler

# 環境設定
# development: ローカル開発環境
# staging: ステージング環境
# production: 本番環境
NODE_ENV=development

# CORS許可オリジン（カンマ区切りで複数指定可）
# LOCAL: http://localhost:5173
# STG: https://staging-shift-scheduler-ai.vercel.app
# PRD: https://shift-scheduler-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# デフォルト設定値
# ハードコーディングを避けるため、設定値を環境変数で管理

# デフォルトテナントID（マルチテナント対応）
DEFAULT_TENANT_ID=1

# デフォルト店舗ID
DEFAULT_STORE_ID=1

# デモ・開発用設定
DEMO_PLAN_ID=4
DEMO_STAFF_ID=5
DEMO_YEAR=2024
DEMO_MONTH=10

# LIFF Backend URL（LINE通知送信用）
# LOCAL: http://localhost:3001
# STG: https://shift-scheduler-ai-liff-backend-staging-staging.up.railway.app
# PRD: https://shift-scheduler-ai-liff-production.up.railway.app
LIFF_BACKEND_URL=http://localhost:3001

# 月次第一案バッチ認証キー（POST /api/shifts/plans/monthly-first-plan-batch）
# `openssl rand -hex 32` などで生成し、GitHub Secrets の BATCH_API_KEY と同じ値を設定する
BATCH_API_KEY=your-batch-api-key-here
